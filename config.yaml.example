# config.yaml.example
# Copy this file to config.yaml and adjust values as needed.
# DO NOT commit config.yaml to version control.

location:
  name: "New York, US"
  latitude: 40.7128
  longitude: -74.0060

display:
  refresh_interval_minutes: 30
  forecast_days: 5
  hourly_slots: 8

units:
  temperature: "C"        # "C" for Celsius, "F" for Fahrenheit

alerts:
  temp_high_threshold: 35   # degrees C - red color warning
  temp_low_threshold: -5    # degrees C - red color warning
  precip_threshold: 10      # mm - red color alert
